rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Users are keyed by UID.
    match /users/{uid} {
      allow read, write: if signedIn() && uid == request.auth.uid;
      allow read, write: if isAdmin();
    }

    match /plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /lectures/{lectureId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /payments/{paymentId} {
      allow create: if signedIn()
        && request.resource.data.authUid == request.auth.uid
        && request.resource.data.email == request.auth.token.email;
      allow read: if isAdmin() || (signedIn() && resource.data.authUid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /signals/{signalId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /signalsRequests/{requestId} {
      allow create: if signedIn()
        && request.resource.data.authUid == request.auth.uid
        && request.resource.data.email == request.auth.token.email;
      allow read: if isAdmin() || (signedIn() && resource.data.authUid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /signalCalls/{requestId} {
      allow create: if signedIn()
        && request.resource.data.email == request.auth.token.email;
      allow read: if isAdmin() || (signedIn() && resource.data.email == request.auth.token.email);
      allow update, delete: if isAdmin();
    }

    match /liveSessions/{requestId} {
      allow create: if signedIn()
        && request.resource.data.authUid == request.auth.uid
        && request.resource.data.email == request.auth.token.email;
      allow read: if isAdmin() || (signedIn() && resource.data.authUid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /selectiveAccessRequests/{requestId} {
      allow create: if isAdmin();
      allow read: if isAdmin() || (signedIn() && resource.data.authUid == request.auth.uid);
      // Users may update their own request (e.g. accept/reject flow from dashboard).
      allow update: if isAdmin() || (signedIn() && resource.data.authUid == request.auth.uid);
      allow delete: if isAdmin() || (signedIn() && resource.data.authUid == request.auth.uid);
    }

    match /selectiveAccessGrants/{uid} {
      allow read: if signedIn() && uid == request.auth.uid;
      allow write: if isAdmin() || (signedIn() && uid == request.auth.uid);
    }

    match /selectedUsers/{uid} {
      allow read, write: if isAdmin() || (signedIn() && uid == request.auth.uid);
    }
  }
}

